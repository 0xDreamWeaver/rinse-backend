# Rinse Backend Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# Database Configuration
# =============================================================================

# SQLite database path
# Default: sqlite:data/rinse.db
DATABASE_URL=sqlite:data/rinse.db

# =============================================================================
# Storage Configuration
# =============================================================================

# Directory where downloaded files will be stored
# Default: storage
STORAGE_PATH=storage

# =============================================================================
# Server Configuration
# =============================================================================

# Address and port the server will bind to
# Use 0.0.0.0 for all interfaces (production)
# Use 127.0.0.1 for localhost only (development)
# Default: 0.0.0.0:3000
BIND_ADDR=127.0.0.1:3000

# =============================================================================
# Authentication
# =============================================================================

# Secret key for JWT token generation
# IMPORTANT: Change this in production! Use a long, random string.
# Generate with: openssl rand -base64 32
JWT_SECRET=change-me-in-production

# =============================================================================
# Soulseek Configuration
# =============================================================================

# Your Soulseek account credentials
# These are required for the application to connect to Soulseek network
# and download files.
#
# IMPORTANT:
# - Use a dedicated Soulseek account for this service
# - Do NOT use your personal Soulseek account
# - Keep these credentials secure

SLSK_USERNAME=your-soulseek-username
SLSK_PASSWORD=your-soulseek-password

# =============================================================================
# External Services Configuration
# =============================================================================

# GetSongBPM API for BPM/Key metadata lookup
GETSONGBPM_API_KEY=6e6b2846b5efd5045c40fdbc14bb6a3f
# MusicBrainz Contact Email
MUSICBRAINZ_CONTACT_EMAIL=0xdreamweaver@tutanota.com


# =============================================================================
# SMTP Configuration (for email verification)
# =============================================================================

# SMTP server settings
# If not configured, email verification will be disabled
# Users will still need to be manually verified in the database

# SMTP host (e.g., smtp.gmail.com, smtp.sendgrid.net)
SMTP_HOST=smtp.gmail.com

# SMTP port (465 for implicit TLS recommended, 587 for STARTTLS)
SMTP_PORT=465

# SMTP authentication credentials
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Sender email address and display name
SMTP_FROM_EMAIL=noreply@rinse.app
SMTP_FROM_NAME=Rinse

# Frontend URL (used for verification links in emails)
# This should be the URL where your frontend is accessible
APP_URL=http://localhost:5173

# =============================================================================
# Logging
# =============================================================================

# Logging level
# Options: trace, debug, info, warn, error
# Default: info
RUST_LOG=info

# For more detailed logging during development:
# RUST_LOG=debug

# For very verbose logging (includes protocol messages):
# RUST_LOG=trace

# For specific module logging:
# RUST_LOG=rinse_backend=debug,rinse_backend::protocol=trace